{
    "version": 2,
    "functions": {
        "api/index.js": {
            "maxDuration": 120
        }
    },
    "rewrites": [
        {
            "source": "/api/midtrans/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/api/notify-resi",
            "destination": "/api/index.js"
        },
        {
            "source": "/api/orders/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/backend/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/"
        }
    ]
}